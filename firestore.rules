rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users collection ──
    // Only the authenticated user can read/write their own document.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Danger Reports collection ──
    // Any authenticated user can read reports.
    // Only the reporter can create; anyone can upvote (update).
    match /dangerReports/{reportId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null 
                    && resource.data.reportedBy == request.auth.uid;
    }

    // ── SOS Events collection ──
    // Only the creator can write.
    // Anyone authenticated can read (for community awareness).
    match /sosEvents/{eventId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null 
                    && resource.data.userId == request.auth.uid;
      allow delete: if false; // SOS events are immutable
    }
  }
}
